# Resend API Key (문의 폼 이메일 발송)
# https://resend.com 에서 발급
RESEND_API_KEY=your_resend_api_key_here

# 도메인 등록 전 테스트용 발신 주소 (도메인 인증 후 삭제)
# RESEND_FROM_EMAIL=onboarding@resend.dev

# 사이트 URL (Vercel 배포 후 실제 URL로 변경)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Kakao Map API Key
# https://developers.kakao.com 에서 JavaScript 키 발급
NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_map_key_here
